# =============================================================================
# GalaxyBots.ai — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
out/
build/
tmp/
out-tsc/
*.tsbuildinfo

# Expo / React Native
.expo/
.expo-shared/

# -----------------------------------------------------------------------------
# Environment & secrets
# Never commit .env files — use Replit Secrets instead.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Replit platform internals
# -----------------------------------------------------------------------------
.cache/
.local/
.config/
.replit
.replitignore

# Cursor / GitHub Copilot rule files added by Replit
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# -----------------------------------------------------------------------------
# Agent session files
# Generated each session — must not be committed.
# -----------------------------------------------------------------------------
attached_assets/
.agents/

# -----------------------------------------------------------------------------
# Generated exports & reports
# Runtime outputs created by bots/agents — not source code.
# -----------------------------------------------------------------------------
exports/
reports/

# -----------------------------------------------------------------------------
# Large binary assets
# Store in cloud/shared drive, not in git history.
# -----------------------------------------------------------------------------
*.pdf
*.pptx
*.docx
*.xlsx
*.zip

# -----------------------------------------------------------------------------
# Misc / logs / leftover debris
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-error.log
/coverage
/libpeerconnection.log
testem.log
/typings
/.sass-cache
/connect.lock
conflict_block.txt
resolution.txt
part1.txt
part2.txt
